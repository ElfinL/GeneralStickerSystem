{
  "manifest_version": 3,
  "name": "DLive Sticker Quick",
  "version": "2.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "description": "Save sticker IDs and send them as chat messages with one click.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://dlive.tv/*",
    "https://www.dlive.tv/*",
    "https://*.dlive.tv/*",
    "https://graphigo.prd.dlive.tv/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "DLive Sticker Quick",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://dlive.tv/*",
        "https://www.dlive.tv/*",
        "https://*.dlive.tv/*"
      ],
      "js": ["stickerStorage.js", "stickerTags.js", "content.js"]
    }
  ]
}