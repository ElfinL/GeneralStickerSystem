{
  "manifest_version": 3,
  "name": "DLive Sticker Quick",
  "version": "1.6",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "description": "儲存貼圖 ID 並一鍵送出聊天訊息",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://dlive.tv/*",
    "https://graphigo.prd.dlive.tv/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "DLive Sticker Quick",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://dlive.tv/*"],
      "js": ["content.js"]
    }
  ]
}